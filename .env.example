# Gong API (see https://app.gong.io/settings/api/documentation)
# Copy to .env and fill in — never commit .env

GONG_ACCESS_KEY=
# Use either GONG_ACCESS_SECRET or GONG_ACCESS_KEY_SECRET (Gong-issued secret).
# Quote the value if it is a JWT (contains =), e.g. GONG_ACCESS_KEY_SECRET="eyJ..."
GONG_ACCESS_KEY_SECRET=

# Regional API root including /v2 (from your Gong API settings)
# GONG_API_BASE_URL=https://us-XXXX.api.gong.io/v2

# Optional app URL for humans (not used by the script)
# GONG_WEB_APP_URL=https://us-XXXX.app.gong.io

# Webhook signing secret (for inbound webhooks only — not used by list script)
# GONG_WEBHOOK_SECRET=

# Optional
# GONG_BASE_URL=https://api.gong.io
# DATE_WINDOW_MODE=calendar-sun-to-sun
# DAYS=7
#   - Used only when DATE_WINDOW_MODE=rolling-days
#
# How to filter calls (MATCH):
#   party-title (default) — participant job title contains PARTY_TITLE_SUBSTRING (Gong parties[].title)
#   field-engineer — same as party-title
#   field — JSON property key named "engineer"
#   text — any string in payload matches /engineer/i
# MATCH=party-title
# PARTY_TITLE_SUBSTRING=Field Engineer

# Supabase (source of truth for runs/calls/feedback items)
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
#   - Legacy fallback; prefer SUPABASE_SECRET_KEY
#
# Storage controls:
# WRITE_SUPABASE=true
# WRITE_LOCAL_JSON=false

# Supabase project ID (required for Notion sync via MCP)
# SUPABASE_PROJECT_ID=

# Notion sync (push-to-notion.mjs)
# NOTION_DATABASE_URL=
# NOTION_DATA_SOURCE_URL=
# RUN_ID=
# MAX_ITEMS=1000
# DRY_RUN=false

# Slack digest (post-to-slack.mjs)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_TOP_N=5
# DISTILL_MODEL=anthropic/claude-sonnet-4-20250514
# ANALYZE_MODEL=anthropic/claude-sonnet-4-20250514
# ANALYZE_TOP_N=5
# ANALYZE_MAX_PROMPT_ITEMS=500
# ANALYSIS_OUTPUT_PATH=data/runs/<run-id>/analysis.json
# REUSE_ANALYSIS=true
